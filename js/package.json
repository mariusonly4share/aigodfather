    "directory": "js"
  },
  "keywords": [
    "ai",
    "monitoring",
    "agents",
    "aigodfather",
    "observability",
    "incidents",
    "eu-ai-act",
    "error-tracking",
    "event-tracking",
    "typescript"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
