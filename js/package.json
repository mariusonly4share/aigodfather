{
  "name": "aigodfather",
  "version": "2.1.0",
  "description": "Official JavaScript/TypeScript SDK for AIGodfather - AI Agent Monitoring",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "homepage": "https://www.aigodfather.ai",
  "bugs": {
